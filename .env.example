# .env.example - Configuration template

# Minecraft Server
MINECRAFT_HOST=localhost
MINECRAFT_PORT=25565
MINECRAFT_USERNAME=AIBot
# MINECRAFT_PASSWORD=your-password-here  # If server requires auth

# Omniroute API
OMNIROUTE_URL=http://127.0.0.1:20128/v1/chat/completions
OMNIROUTE_API_KEY=sk-25dccb8ba99cb3cf-6f2993-0a542c8e

# Model Selection
PILOT_MODEL=nvidia/meta/llama-3.2-1b-instruct
STRATEGY_MODEL=nvidia/qwen/qwen2.5-7b-instruct
COMMANDER_MODEL=claude-sonnet-4.5

# Loop Intervals (milliseconds)
PILOT_INTERVAL=500
STRATEGY_INTERVAL=3000
COMMANDER_INTERVAL=10000

# Voice (optional)
WHISPER_MODEL=base
WHISPER_LANGUAGE=pl
TTS_VOICE=en_US-lessac-high

# Debug
DEBUG=false
LOG_LEVEL=info
